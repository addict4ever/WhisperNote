<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WhisperNote.Views.RecordsPage"
             BackgroundColor="#0F111A"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="True"
             Shell.FlyoutItemIsVisible="False">          

    <Grid RowDefinitions="Auto, *" Padding="15" RowSpacing="10">

        <Label Grid.Row="0" 
               Text="BIBLIOTHÈQUE AUDIO" 
               FontSize="{OnPlatform WinUI=28, Android=22, iOS=22}" 
               FontAttributes="Bold" 
               TextColor="#82AAFF" 
               HorizontalOptions="Center"
               Margin="0,10"/>

        <CollectionView Grid.Row="1" x:Name="RecordsListView">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" 
                                 Span="{OnIdiom Phone=1, Tablet=2, Desktop=3}" 
                                 HorizontalItemSpacing="10" 
                                 VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#161821" 
                            StrokeThickness="1" 
                            Stroke="#2D334A"
                            StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Padding="15" Spacing="12">

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Name}" 
                                           TextColor="White" 
                                           FontSize="15" 
                                           LineBreakMode="TailTruncation"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding CreationDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}" 
                                           TextColor="#676E95" 
                                           FontSize="12"/>
                                </VerticalStackLayout>

                                <Label Grid.Column="1" 
                                       Text="{Binding SizeLabel}" 
                                       TextColor="#82AAFF" 
                                       FontSize="11" 
                                       VerticalOptions="Start"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#2D334A" Opacity="0.5"/>

                            <FlexLayout JustifyContent="SpaceEvenly" AlignItems="Center" Wrap="NoWrap">
                                <Button Text="▶️" Clicked="OnPlayRecord" CommandParameter="{Binding .}" 
                                        BackgroundColor="#2D334A" CornerRadius="8" WidthRequest="60" HeightRequest="45"/>

                                <Button Text="📝" Clicked="OnTranscribeRecord" CommandParameter="{Binding .}" 
                                        BackgroundColor="#2D334A" CornerRadius="8" WidthRequest="60" HeightRequest="45"/>

                                <Button Text="📤" Clicked="OnShareRecord" CommandParameter="{Binding .}" 
                                        BackgroundColor="#2D334A" CornerRadius="8" WidthRequest="60" HeightRequest="45"/>

                                <Button Text="🗑️" Clicked="OnDeleteRecord" CommandParameter="{Binding .}" 
                                        BackgroundColor="#452727" TextColor="#FF5252" CornerRadius="8" WidthRequest="60" HeightRequest="45"/>
                            </FlexLayout>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50" Spacing="10">
                    <Label Text="🔇" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="Aucun enregistrement trouvé." 
                           TextColor="#464B5D" 
                           FontSize="14"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>